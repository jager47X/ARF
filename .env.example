# Required — OpenAI API key for LLM reranking and summary generation
OPENAI_API_KEY=

# Required — Voyage AI API key for embedding generation (voyage-3-large)
VOYAGE_API_KEY=

# Required — MongoDB Atlas connection string (must have vector search enabled)
MONGO_URI=

# Optional — set to "true" to enable automatic weekly USCIS policy updates
USCIS_AUTOUPDATE_ENABLED=false

# Optional — set when running inside Docker (local | dev | production)
# DOCKER_ENV=
